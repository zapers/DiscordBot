# Get your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Optional: your server (guild) ID for instant slash command updates during development
# GUILD_ID=your_guild_id_here

# Optional: API key for the web app (send/schedule from browser). If not set, the API only works from localhost.
# API_KEY=your_secret_key

# Optional: port for the web app (default 3000)
# PORT=3000
